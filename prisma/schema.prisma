generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          Role
  image         String?
  isActive      Boolean   @default(true)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  Parent        Parent?
  sessions      Session[]
  student       Student?
  teacher       Teacher?

  @@index([email])
  @@index([role])
}

model Result {
  id String @id @default(cuid())

  examId String

  studentId String

  total Float

  average Float

  position Int?

  grade String?

  remark String?

  teacherComment String?

  principalComment String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  exam Exam @relation(fields: [examId], references: [id])

  student Student @relation(fields: [studentId], references: [id])

  subjects ResultSubject[]

  @@unique([examId, studentId])
  @@index([examId])
  @@index([studentId])
}

model ResultSubject {
  id String @id @default(cuid())

  resultId String

  subjectId String

  ca Float

  exam Float

  total Float

  grade String

  remark String

  result Result @relation(fields: [resultId], references: [id])

  subject Subject @relation(fields: [subjectId], references: [id])

  @@index([resultId])
  @@index([subjectId])
}

model GradingSystem {
  id String @id @default(cuid())

  grade String

  minimum Float

  maximum Float

  remark String

  points Float
}

model AcademicSession {
  id          String       @id @default(cuid())
  name        String       @unique
  isCurrent   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  endDate     DateTime?
  startDate   DateTime?
  attendance  Attendance[]
  enrollments Enrollment[]
  terms       Term[]
  exams       Exam[]
}

model Teacher {
  id              String           @id @default(cuid())
  employeeId      String           @unique
  firstName       String
  lastName        String
  email           String?          @unique
  phone           String?
  gender          Gender
  status          TeacherStatus    @default(ACTIVE)
  userId          String?          @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  address         String?
  departmentId    String?
  dob             DateTime?
  employmentDate  DateTime?
  middleName      String?
  passport        String?
  qualification   String?
  specialization  String?
  classTeacherOf  Class[]          @relation("ClassTeacher")
  department      Department?      @relation(fields: [departmentId], references: [id])
  user            User?            @relation(fields: [userId], references: [id])
  teacherSubjects TeacherSubject[]

  @@index([employeeId])
  @@index([departmentId])
  @@index([status])
}

model Subject {
  id              String           @id @default(cuid())
  name            String
  code            String           @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  description     String?
  classSubjects   ClassSubject[]
  teacherSubjects TeacherSubject[]
  examSubjects    ExamSubject[]
  examScores      ExamScore[]
  resultSubjects  ResultSubject[]

  @@index([code])
  @@index([name])
}

model TeacherSubject {
  id        String   @id @default(cuid())
  teacherId String
  subjectId String
  createdAt DateTime @default(now())
  subject   Subject  @relation(fields: [subjectId], references: [id])
  teacher   Teacher  @relation(fields: [teacherId], references: [id])

  @@unique([teacherId, subjectId])
  @@index([teacherId])
  @@index([subjectId])
}

model ClassSubject {
  id        String   @id @default(cuid())
  classId   String
  subjectId String
  createdAt DateTime @default(now())
  class     Class    @relation(fields: [classId], references: [id])
  subject   Subject  @relation(fields: [subjectId], references: [id])

  @@unique([classId, subjectId])
  @@index([classId])
  @@index([subjectId])
}

model Class {
  id             String         @id @default(cuid())
  name           String
  arm            String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  capacity       Int?
  classTeacherId String?
  description    String?
  room           String?
  attendance     Attendance[]
  classTeacher   Teacher?       @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  classSubjects  ClassSubject[]
  enrollments    Enrollment[]
  students       Student[]
  examClasses    ExamClass[]

  @@unique([name, arm])
  @@index([classTeacherId])
}

model Parent {
  id             String    @id @default(cuid())
  firstName      String
  lastName       String
  phone          String
  email          String?
  occupation     String?
  address        String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  alternatePhone String?
  employer       String?
  gender         Gender?
  middleName     String?
  passport       String?
  relationship   String?
  dob            DateTime?
  nationality    String?
  state          String?
  userId         String?   @unique
  user           User?     @relation(fields: [userId], references: [id])
  students       Student[]

  @@index([phone])
  @@index([email])
}

model Student {
  id               String        @id @default(cuid())
  admissionNumber  String        @unique
  firstName        String
  middleName       String?
  lastName         String
  gender           Gender
  dob              DateTime
  state            String?
  nationality      String?
  religion         String?
  address          String?
  phone            String?
  email            String?
  allergies        String?
  medicalCondition String?
  emergencyContact String?
  status           StudentStatus @default(ACTIVE)
  passport         String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  userId           String?       @unique
  parentId         String?
  classId          String?
  admissionDate    DateTime?
  admissionType    String?
  house            String?
  lga              String?
  medicalNotes     String?
  previousSchool   String?
  bloodGroup       BloodGroup?
  genotype         Genotype?
  attendance       Attendance[]
  enrollments      Enrollment[]
  examScores       ExamScore[]
  results          Result[]
  class            Class?        @relation(fields: [classId], references: [id])
  parent           Parent?       @relation(fields: [parentId], references: [id])
  user             User?         @relation(fields: [userId], references: [id])

  @@index([admissionNumber])
  @@index([classId])
  @@index([parentId])
  @@index([status])
}

model Enrollment {
  id        String          @id @default(cuid())
  studentId String
  classId   String
  sessionId String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  class     Class           @relation(fields: [classId], references: [id])
  session   AcademicSession @relation(fields: [sessionId], references: [id])
  student   Student         @relation(fields: [studentId], references: [id])

  @@unique([studentId, sessionId])
  @@index([studentId])
  @@index([classId])
  @@index([sessionId])
}

model Department {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  hodId       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  teachers    Teacher[]

  @@index([name])
}

model Term {
  id        String          @id @default(cuid())
  name      String
  sessionId String
  createdAt DateTime        @default(now())
  endDate   DateTime?
  isCurrent Boolean         @default(false)
  startDate DateTime?
  updatedAt DateTime        @updatedAt
  session   AcademicSession @relation(fields: [sessionId], references: [id])
  exams     Exam[]

  @@index([sessionId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Attendance {
  id        String           @id @default(cuid())
  studentId String
  classId   String
  sessionId String
  date      DateTime
  status    AttendanceStatus @default(PRESENT)
  remarks   String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  class     Class            @relation(fields: [classId], references: [id])
  session   AcademicSession  @relation(fields: [sessionId], references: [id])
  student   Student          @relation(fields: [studentId], references: [id])

  @@unique([studentId, date])
  @@index([studentId])
  @@index([classId])
  @@index([sessionId])
  @@index([date])
}

model Exam {
  id String @id @default(cuid())

  name String

  sessionId String
  termId    String

  totalMark Int @default(100)

  status ExamStatus @default(DRAFT)

  startDate DateTime?
  endDate   DateTime?

  description String?

  isPublished Boolean @default(false)

  session AcademicSession @relation(fields: [sessionId], references: [id])

  term Term @relation(fields: [termId], references: [id])

  classes ExamClass[]

  subjects ExamSubject[]

  scores    ExamScore[]
  results   Result[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([name, sessionId, termId])
  @@index([sessionId])
  @@index([termId])
  @@index([status])
}

model ExamClass {
  id String @id @default(cuid())

  examId  String
  classId String

  exam Exam @relation(fields: [examId], references: [id])

  class Class @relation(fields: [classId], references: [id])

  createdAt DateTime @default(now())

  @@unique([examId, classId])
  @@index([examId])
  @@index([classId])
}

model ExamSubject {
  id String @id @default(cuid())

  examId String

  subjectId String

  exam Exam @relation(fields: [examId], references: [id])

  subject Subject @relation(fields: [subjectId], references: [id])

  createdAt DateTime @default(now())

  @@unique([examId, subjectId])
  @@index([examId])
  @@index([subjectId])
}

model ExamScore {
  id String @id @default(cuid())

  examId    String
  studentId String
  subjectId String

  caScore Float @default(0)

  examScore Float @default(0)

  totalScore Float @default(0)

  grade String?

  remark String?

  exam Exam @relation(fields: [examId], references: [id])

  student Student @relation(fields: [studentId], references: [id])

  subject Subject @relation(fields: [subjectId], references: [id])

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@unique([examId, studentId, subjectId])
  @@index([examId])
  @@index([studentId])
  @@index([subjectId])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  TEACHER
  STUDENT
  PARENT
  ACCOUNTANT
  LIBRARIAN
  RECEPTIONIST
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum Gender {
  MALE
  FEMALE
}

enum StudentStatus {
  ACTIVE
  PENDING
  SUSPENDED
  GRADUATED
  TRANSFERRED
}

enum TeacherStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}

enum Genotype {
  AA
  AS
  AC
  SS
  SC
}

enum ExamStatus {
  DRAFT
  ACTIVE
  LOCKED
  PUBLISHED
}
